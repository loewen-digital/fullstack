#!/bin/sh
# Pre-push hook: runs lint, typecheck, and tests before every push.
# Installed automatically via the "prepare" npm script.
# To skip in an emergency: git push --no-verify

set -e

echo "⏳ Running pre-push checks..."

echo "\n▶ lint"
npm run lint

echo "\n▶ typecheck"
npm run typecheck

echo "\n▶ test"
npm run test

echo "\n✅ All checks passed."
