  },
  "bin": {
    "fullstack": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.25.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.30.0",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.5.0",
