      "types": "./dist/events/index.d.ts"
    },
    "./notifications": {
      "import": "./dist/notifications/index.js",
      "types": "./dist/notifications/index.d.ts"
    },
    "./i18n": {
      "import": "./dist/i18n/index.js",
      "types": "./dist/i18n/index.d.ts"
