    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    },
    "./adapters/sveltekit": {
      "import": "./dist/adapters/sveltekit/index.js",
      "types": "./dist/adapters/sveltekit/index.d.ts"
    },
    "./adapters/nuxt": {
      "import": "./dist/adapters/nuxt/index.js",
      "types": "./dist/adapters/nuxt/index.d.ts"
    },
    "./adapters/remix": {
      "import": "./dist/adapters/remix/index.js",
