    },
    "./session": {
      "import": "./dist/session/index.js",
      "types": "./dist/session/index.d.ts"
    },
    "./security": {
      "import": "./dist/security/index.js",
      "types": "./dist/security/index.d.ts"
    },
    "./mail": {
      "import": "./dist/mail/index.js",
      "types": "./dist/mail/index.d.ts"
